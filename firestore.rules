rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'alcanzagrupoinmobiliario@gmail.com';
    }

    function profilePath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasProfile() {
      return isSignedIn() && exists(profilePath());
    }

    function isActive() {
      return hasProfile() && get(profilePath()).data.active != false;
    }

    function isAdmin() {
      return isActive() && (
        request.auth.token.role == 'admin' ||
        (hasProfile() && get(profilePath()).data.role == 'admin')
      );
    }

    function isUser() {
      // tanto 'user' como 'admin' pueden leer/escribir datos operativos
      return isActive() && (
        get(profilePath()).data.role == 'user' ||
        get(profilePath()).data.role == 'admin'
      );
    }

    // ── Datos de planeamiento ─────────────────────────────────────────────────
    // Colección: planeamientos  →  doc: lps2026v5  (y futuros docs)
    match /planeamientos/{docId} {
      allow read, write: if isUser();
    }

    // ── Perfiles de usuario ───────────────────────────────────────────────────
    // Solo los admins crean / modifican perfiles; el propio usuario puede leerlo
    match /users/{userId} {
      allow read:  if isSignedIn() && (isAdmin() || request.auth.uid == userId);
      allow write: if isAdmin();
    }

    // ── Auditoría de accesos y acciones ───────────────────────────────────────
    match /audit_logs/{logId} {
      allow create: if isUser();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }
  }
}
